<section class="hero">
  <p class="hero-kicker">Post Details</p>
  <h1>Post #<%= @post.id %></h1>
  <p>
    Authored by <strong><%= @post.user.name %></strong> on <%= @post.date.strftime("%d %b %Y %H:%M") %>.
    You can also inspect the raw JSON at <a href="/api/v1/posts/<%= @post.id %>">/api/v1/posts/<%= @post.id %></a>.
  </p>
  <div class="hero-links">
    <a class="chip" href="<%= root_path %>">Back to timeline</a>
    <a class="chip" href="<%= timeline_path(user_id: selected_user&.id) %>">Timeline</a>
    <a class="chip" href="/api/v1/posts/<%= @post.id %>">Raw API</a>
  </div>

  <% if available_users.any? %>
    <%= form_with url: timeline_select_user_path, class: "toolbar" do |form| %>
      <%= form.hidden_field :redirect_to, value: timeline_post_path(@post) %>
      <div class="field" style="min-width: 260px;">
        <%= form.label :user_id, "Current user" %>
        <%= form.select :user_id, available_users.map { |user| [ "#{user.name} (##{user.id})", user.id ] }, { selected: selected_user&.id } %>
      </div>
      <%= form.submit "Use this user", class: "button" %>
    <% end %>
  <% end %>
</section>

<article class="card" style="margin-top: 24px;">
  <div class="meta-row">
    <div class="meta">Updated <%= @post.updated_at.strftime("%d %b %Y %H:%M") %></div>
    <div class="stats">
      <%= render "post_like", post: @post %>
      <span class="stat"><%= @post.comments.count %> comments</span>
    </div>
  </div>

  <h2 class="title">Description</h2>
  <p class="body"><%= @post.description %></p>

  <p class="section-label">Attachments</p>
  <section class="attachments">
    <% if @post.post_attachments.any? %>
      <% @post.post_attachments.each do |attachment| %>
        <div class="attachment">
          <strong><%= attachment.file_type.capitalize %></strong>
          <div class="meta"><a href="<%= attachment.url %>"><%= attachment.url %></a></div>
        </div>
      <% end %>
    <% else %>
      <div class="attachment meta">No attachments</div>
    <% end %>
  </section>

  <% if selected_user_owns?(@post) %>
    <section class="soft-panel" style="margin-top: 22px;">
      <div class="meta">Manage from browser</div>
      <h3 class="title" style="font-size: 1.2rem;">Edit or delete this post</h3>
      <p class="meta">You are viewing this post as its author, so you can update the description or remove the post.</p>

      <%= form_with model: @post, url: timeline_post_path(@post, user_id: selected_user.id), method: :patch, class: "form-stack" do |form| %>
        <div class="field">
          <%= form.label :description, "Update description" %>
          <%= form.text_area :description, value: @post.description, placeholder: "Update the post..." %>
        </div>

        <div class="field">
          <%= form.label :attachment_file, "Add another file from your computer" %>
          <%= form.file_field :attachment_file, accept: "image/*,video/*,.pdf,application/pdf" %>
        </div>

        <%= form.submit "Update post", class: "button" %>
      <% end %>

      <div style="margin-top: 14px;">
        <%= button_to "Delete post", timeline_post_path(@post, user_id: selected_user.id), method: :delete, class: "button" %>
      </div>
    </section>
  <% end %>

  <p class="section-label">Comments</p>
  <section class="soft-panel" style="margin-bottom: 20px;">
    <div class="meta">Add from browser</div>
    <h3 class="title" style="font-size: 1.2rem;">New comment</h3>
    <% if selected_user %>
      <p class="meta">Commenting as <strong><%= selected_user.name %></strong>.</p>
    <% end %>
    <%= form_with model: @comment, url: timeline_post_comments_path(@post), class: "form-stack" do |form| %>
      <%= hidden_field_tag :user_id, selected_user&.id %>
      <div class="field">
        <%= form.label :body %>
        <%= form.text_area :body, placeholder: "Write a comment..." %>
      </div>

      <%= form.submit "Add comment", class: "button" %>
    <% end %>
  </section>

  <section class="comments">
    <% if @post.comments.any? %>
      <% @post.comments.order(:created_at).each do |comment| %>
        <div class="comment" id="comment-<%= comment.id %>">
          <div class="meta-row">
            <strong><%= comment.user.name %></strong>
            <span class="meta"><%= comment.likes.count %> likes</span>
          </div>
          <p class="body" style="margin-top: 10px;"><%= comment.body %></p>

          <% if selected_user %>
            <div style="margin-top: 12px;">
              <%= button_to(
                selected_user_liked?(comment) ? "Unlike comment" : "Like comment",
                timeline_comment_like_path(comment, user_id: selected_user.id),
                method: :post,
                class: "button"
              ) %>
            </div>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div class="comment meta">No comments yet</div>
    <% end %>
  </section>
</article>
