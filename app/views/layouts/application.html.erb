<!DOCTYPE html>
<html>
  <head>
    <title>Timeline API</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <script
      src="https://cdn.jsdelivr.net/npm/@hotwired/turbo@8.0.18/dist/turbo.es2017-umd.js"
      defer
    ></script>
    <style>
      :root {
        --bg: #f3ede4;
        --panel: rgba(255, 252, 247, 0.94);
        --panel-strong: rgba(255, 249, 241, 0.98);
        --ink: #1f1d1a;
        --muted: #6b655d;
        --accent: #b4512d;
        --accent-deep: #8d3d20;
        --accent-soft: #ead3c4;
        --line: rgba(31, 29, 26, 0.08);
        --shadow: 0 20px 60px rgba(62, 40, 23, 0.12);
        --shadow-soft: 0 10px 24px rgba(62, 40, 23, 0.08);
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        color: var(--ink);
        font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Georgia, serif;
        background:
          radial-gradient(circle at top left, rgba(180, 81, 45, 0.12), transparent 28%),
          radial-gradient(circle at right 20%, rgba(123, 87, 54, 0.08), transparent 24%),
          linear-gradient(180deg, #fbf6ef 0%, var(--bg) 48%, #eee3d5 100%);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      a:hover {
        color: var(--accent-deep);
      }

      .shell {
        width: min(1160px, calc(100% - 32px));
        margin: 0 auto;
        padding: 28px 0 64px;
      }

      .hero {
        padding: 30px 32px;
        border: 1px solid var(--line);
        border-radius: 30px;
        background: linear-gradient(135deg, rgba(255, 249, 243, 0.98), rgba(244, 232, 220, 0.92));
        box-shadow: var(--shadow);
      }

      .hero-kicker {
        margin: 0 0 10px;
        color: var(--accent);
        font-size: 0.85rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .hero h1 {
        margin: 0;
        max-width: 12ch;
        font-size: clamp(2.3rem, 5vw, 4.3rem);
        line-height: 0.98;
        letter-spacing: -0.03em;
      }

      .hero p {
        max-width: 700px;
        margin: 16px 0 0;
        color: var(--muted);
        font-size: 1.02rem;
        line-height: 1.68;
      }

      .hero-links {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 20px;
      }

      .pagination-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: center;
      }

      .toolbar {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        align-items: end;
        margin-top: 22px;
        padding-top: 18px;
        border-top: 1px solid rgba(31, 29, 26, 0.08);
      }

      .chip {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 10px 15px;
        border: 1px solid rgba(180, 81, 45, 0.16);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.76);
        color: var(--accent);
        font-size: 0.9rem;
        font-weight: 600;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.5);
      }

      .chip-active {
        background: linear-gradient(180deg, var(--accent) 0%, var(--accent-deep) 100%);
        color: #fff8f2;
        border-color: transparent;
      }

      .chip-muted {
        color: rgba(107, 101, 93, 0.75);
        border-color: rgba(31, 29, 26, 0.08);
        background: rgba(255, 255, 255, 0.52);
        pointer-events: none;
      }

      .chip-viewer {
        background: rgba(180, 81, 45, 0.12);
        border-color: rgba(180, 81, 45, 0.18);
        color: var(--accent-deep);
      }

      .grid {
        display: grid;
        gap: 20px;
        margin-top: 24px;
      }

      .split {
        display: grid;
        grid-template-columns: minmax(300px, 360px) 1fr;
        gap: 24px;
        align-items: start;
        margin-top: 24px;
      }

      .card {
        padding: 24px;
        border: 1px solid var(--line);
        border-radius: 24px;
        background: var(--panel);
        box-shadow: var(--shadow-soft);
      }

      .card-top, .meta-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
      }

      .meta {
        color: var(--muted);
        font-size: 0.92rem;
      }

      .title {
        margin: 14px 0 12px;
        font-size: 1.5rem;
        line-height: 1.1;
        letter-spacing: -0.02em;
      }

      .body {
        margin: 0;
        color: #342f29;
        font-size: 1rem;
        line-height: 1.72;
      }

      .stats {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 18px;
      }

      .stat {
        padding: 8px 12px;
        border-radius: 999px;
        background: var(--accent-soft);
        color: #6f3118;
        font-size: 0.88rem;
        font-weight: 600;
      }

      .attachments, .comments {
        display: grid;
        gap: 12px;
        margin-top: 20px;
      }

      .attachment, .comment {
        padding: 14px 16px;
        border: 1px solid var(--line);
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.76);
      }

      .attachment-preview {
        display: block;
        width: 100%;
        max-height: 220px;
        margin-top: 12px;
        object-fit: cover;
        border-radius: 14px;
        border: 1px solid rgba(31, 29, 26, 0.08);
        box-shadow: var(--shadow-soft);
        background: rgba(255, 255, 255, 0.9);
      }

      .author-controls {
        margin-top: 22px;
        border-color: rgba(180, 81, 45, 0.18);
        background:
          linear-gradient(180deg, rgba(255, 250, 245, 0.98), rgba(247, 238, 229, 0.92));
      }

      .author-controls .title {
        margin-top: 8px;
      }

      .section-label {
        margin: 28px 0 12px;
        font-size: 0.78rem;
        color: var(--accent);
        letter-spacing: 0.16em;
        text-transform: uppercase;
      }

      .empty {
        color: var(--muted);
        text-align: center;
        padding: 34px 18px;
      }

      .flash {
        margin-top: 18px;
        padding: 14px 18px;
        border-radius: 18px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.88);
        box-shadow: var(--shadow-soft);
      }

      .flash.notice {
        color: #24553f;
        background: rgba(225, 243, 232, 0.92);
      }

      .flash.alert {
        color: #7a281d;
        background: rgba(251, 229, 224, 0.92);
      }

      .form-stack {
        display: grid;
        gap: 14px;
      }

      .field {
        display: grid;
        gap: 6px;
      }

      .field label {
        color: var(--muted);
        font-size: 0.9rem;
        font-weight: 600;
      }

      .field input,
      .field select,
      .field textarea {
        width: 100%;
        padding: 12px 14px;
        color: var(--ink);
        font: inherit;
        border: 1px solid rgba(31, 29, 26, 0.12);
        border-radius: 14px;
        background: rgba(255, 255, 255, 0.96);
        transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
      }

      .field input:focus,
      .field select:focus,
      .field textarea:focus {
        outline: none;
        border-color: rgba(180, 81, 45, 0.45);
        box-shadow: 0 0 0 4px rgba(180, 81, 45, 0.08);
      }

      .field textarea {
        min-height: 128px;
        resize: vertical;
      }

      .button {
        display: inline-flex;
        justify-content: center;
        align-items: center;
        min-height: 46px;
        padding: 12px 18px;
        border: 1px solid transparent;
        border-radius: 999px;
        background: linear-gradient(180deg, var(--accent) 0%, var(--accent-deep) 100%);
        color: #fff8f2;
        font: inherit;
        font-weight: 600;
        cursor: pointer;
        box-shadow: 0 10px 20px rgba(141, 61, 32, 0.18);
        transition: transform 0.15s ease, box-shadow 0.15s ease, opacity 0.15s ease;
      }

      .button:hover {
        transform: translateY(-1px);
        box-shadow: 0 14px 24px rgba(141, 61, 32, 0.2);
      }

      .button:active {
        transform: translateY(0);
      }

      .button_to {
        margin: 0;
      }

      .button_to .button {
        width: auto;
      }

      .like-box {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
      }

      turbo-frame {
        display: inline-flex;
      }

      .soft-panel {
        padding: 18px;
        border: 1px solid var(--line);
        border-radius: 20px;
        background: var(--panel-strong);
      }

      .list-title {
        margin: 0 0 8px;
        font-size: 1.1rem;
      }

      .stack-tight {
        display: grid;
        gap: 10px;
      }

      @media (max-width: 640px) {
        .shell {
          width: min(100% - 20px, 100%);
          padding-top: 20px;
        }

        .split {
          grid-template-columns: 1fr;
        }

        .hero, .card {
          border-radius: 20px;
          padding: 18px;
        }

        .toolbar {
          align-items: stretch;
        }

        .button,
        .button_to .button {
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <main class="shell">
      <% if defined?(@banner) && @banner.present? %>
        <div class="flash <%= @banner.include?("created") || @banner.include?("added") ? "notice" : "alert" %>"><%= @banner %></div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
